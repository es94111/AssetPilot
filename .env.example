# ──────────────────────────────────────────
# VitaTrack 環境變數範例
# 複製此檔案為 .env 並填入實際值
# 注意：.env 已加入 .gitignore，請勿提交
# ──────────────────────────────────────────

# Database
DATABASE_URL=postgresql://vitatrack:devpassword@localhost:5432/vitatrack
POSTGRES_DB=vitatrack
POSTGRES_USER=vitatrack
POSTGRES_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
JWT_EXPIRES_IN=24h

# Application
NODE_ENV=production
PORT=3001

# GitHub Container Registry (CI/CD)
GITHUB_REPOSITORY=your_github_username/vitatrack
