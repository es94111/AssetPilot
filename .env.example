# ──────────────────────────────────────────
# VitaTrack 環境變數範例
# 複製此檔案為 .env 並填入實際值
# 注意：.env 已加入 .gitignore，請勿提交
# ──────────────────────────────────────────

# 資料庫
POSTGRES_DB=vitatrack
POSTGRES_USER=vitatrack
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://vitatrack:your_secure_password_here@db:5432/vitatrack

# JWT 認證
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=24h

# 應用程式
NODE_ENV=production
PORT=3000

# GitHub Container Registry（CI/CD 使用）
GITHUB_REPOSITORY=your_github_username/vitatrack
