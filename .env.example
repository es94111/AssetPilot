# 伺服器設定
PORT=3000

# JWT 設定
JWT_SECRET=your-secret-key-here
JWT_EXPIRES=7d

# Google SSO 設定（至 Google Cloud Console 取得）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 資料庫加密金鑰（ChaCha20-Poly1305）
# 設定後資料庫會自動加密，留空則不加密
# ⚠️ 設定後不可遺失，否則無法讀取資料庫
DB_ENCRYPTION_KEY=

# 匯率 API 設定
# 預設使用免費版 API（無需 key）；若需更高配額或 webhook 功能，可至 https://www.exchangerate-api.com 申請付費 key
EXCHANGE_RATE_API_KEY=free

# CORS 允許來源（逗號分隔，留空則不限制）
# 正式環境建議設定，例如：https://asset.shao.one,http://localhost:3000
ALLOWED_ORIGINS=

# 管理員 IP 白名單（逗號分隔，可留空）
# 白名單 IP 將略過 API 速率限制，避免管理員被誤封鎖
ADMIN_IP_ALLOWLIST=

# mTLS 設定（Cloudflare-issued Client Certificates）
# MTLS_ENABLED=true    → 啟用 mTLS，/api/ 路由（除 auth）必須通過憑證驗證
# MTLS_CF_ONLY=true    → 僅接受 Cloudflare header 驗證（適合純 Cloudflare 代理部署，預設值）
# MTLS_CF_ONLY=false   → 允許直連 HTTPS + TLS 客戶端憑證驗證（需設定 SSL_CERT / SSL_KEY）
MTLS_ENABLED=false
MTLS_CF_ONLY=true

# HTTPS 憑證路徑（使用 Cloudflare Origin Certificate，MTLS_CF_ONLY=false 直連模式時必填）
# SSL_CERT=SSL/Origin Certificates/server.pem   # Cloudflare Origin Certificate（serverAuth）
# SSL_KEY=SSL/Origin Certificates/server.key    # Origin Certificate 私鑰
# MTLS_CA_CERT=SSL/mTLS/cloudflare-ca.pem       # Cloudflare Managed CA 根憑證（至 Dashboard 下載，用於驗證客戶端 mTLS 憑證鏈）

# 版本更新檢查 URL 固定由系統內建，不提供環境變數覆蓋
