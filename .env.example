# 伺服器設定
PORT=3000

# JWT 設定
JWT_SECRET=your-secret-key-here
JWT_EXPIRES=7d

# Google SSO 設定（至 Google Cloud Console 取得）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth redirect_uri 白名單（FR-011）
# 逗號分隔；必須與 Google Cloud Console > OAuth 2.0 Client > Authorized redirect URIs 完全一致
# 預設空字串時 server 會 fallback 至 [https://<APP_HOST>/api/auth/google, http://localhost:<PORT>/api/auth/google]
# 範例：https://app.your-domain.tld/api/auth/google,http://localhost:3000/api/auth/google
GOOGLE_OAUTH_REDIRECT_URIS=

# 對外主機名（Passkey RP ID 推導 / Google redirect_uri fallback 推導）
# 正式部署時請填實際網域，例如：app.your-domain.tld
APP_HOST=localhost

# 資料庫加密金鑰（ChaCha20-Poly1305）
# 設定後資料庫會自動加密，留空則不加密
# ⚠️ 設定後不可遺失，否則無法讀取資料庫
DB_ENCRYPTION_KEY=

# 匯率 API 設定
# 預設使用免費版 API（無需 key）；若需更高配額或 webhook 功能，可至 https://www.exchangerate-api.com 申請付費 key
EXCHANGE_RATE_API_KEY=free

# CORS 允許來源（逗號分隔，留空則不限制）
# 正式環境建議設定，例如：https://asset.shao.one,http://localhost:3000
ALLOWED_ORIGINS=

# 管理員 IP 白名單（逗號分隔，可留空）
# 白名單 IP 將略過 API 速率限制，避免管理員被誤封鎖
ADMIN_IP_ALLOWLIST=

# SSL 憑證根目錄（Docker 部署時建議指向 Volume 路徑，確保憑證持久化）
# 預設：<專案目錄>/SSL/   Docker 預設：/app/data/SSL/（已由 Dockerfile 的 ENV SSL_PATH 設定）
# SSL_PATH=/app/data/SSL

# Cloudflare Origin Certificate 路徑（透過管理員面板上傳並儲存於 SSL/Origin Certificates/）
# SSL_CERT=SSL/Origin Certificates/server.pem
# SSL_KEY=SSL/Origin Certificates/server.key

# 寄信通道（用於管理員寄送資產統計報表）
# 支援三種：smtp / zeabur / resend；以下兩個變數指定主要與備用通道（皆可留空，留空則停用該通道）
# - PRIMARY 留空：寄信功能停用
# - FALLBACK 留空或與 PRIMARY 相同：不啟用 fallback
# - PRIMARY 執行期失敗時若 FALLBACK 已設定才會自動退回（不重試、不補寄）
EMAIL_PROVIDER_PRIMARY=
EMAIL_PROVIDER_FALLBACK=

# 寄信人顯示名稱（三通道共用，例：AssetPilot、我的記帳系統）
# 設定後信件寄件人會顯示為「名稱 <email>」；若下方任一 FROM 變數已是「Name <email>」格式則不覆寫該通道
EMAIL_SENDER_NAME=AssetPilot

# SMTP 寄信（搭配 EMAIL_PROVIDER_*=smtp 使用）
# 範例：Gmail 587（STARTTLS，SMTP_SECURE=false）或 465（TLS，SMTP_SECURE=true）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AssetPilot <noreply@example.com>

# Zeabur Email / ZSend（搭配 EMAIL_PROVIDER_*=zeabur 使用）
# 文件：https://zeabur.com/docs/en-US/email/quick-start
# API Key 至 Zeabur 控制台 > Email > API Keys 取得；FROM_EMAIL 必須是已驗證的寄件網域
ZEABUR_API_KEY=
ZEABUR_FROM_EMAIL=AssetPilot <noreply@example.com>

# Resend 寄信服務（搭配 EMAIL_PROVIDER_*=resend 使用）
# API Key 可至 https://resend.com/api-keys 取得；FROM 必須是已驗證的網域信箱
RESEND_API_KEY=
RESEND_FROM_EMAIL=AssetPilot <noreply@example.com>

# 統計報表信件 CTA 按鈕網址（留空則信件不顯示「前往儀表板」按鈕）
# 範例：https://asset.shao.one
APP_URL=

# 版本更新檢查 URL 固定由系統內建，不提供環境變數覆蓋

# ipinfo.io 查詢 Token（可留空採匿名額度，FR-041 國家代碼 fallback）
IPINFO_TOKEN=

# TWSE 並發查詢上限，預設 5；管理員可調節以避免被 rate limit
# 影響範圍：批次查價、同步除權息（年份分批內部）、排程補產生（每期歷史股價查詢）、Modal 自動回填
TWSE_MAX_CONCURRENCY=5
