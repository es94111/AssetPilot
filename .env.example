# 伺服器設定
PORT=3000

# JWT 設定
JWT_SECRET=your-secret-key-here
JWT_EXPIRES=7d

# Google SSO 設定（至 Google Cloud Console 取得）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 資料庫加密金鑰（ChaCha20-Poly1305）
# 設定後資料庫會自動加密，留空則不加密
# ⚠️ 設定後不可遺失，否則無法讀取資料庫
DB_ENCRYPTION_KEY=

# 匯率 API 設定
# 預設使用免費版 API（無需 key）；若需更高配額或 webhook 功能，可至 https://www.exchangerate-api.com 申請付費 key
EXCHANGE_RATE_API_KEY=free

# CORS 允許來源（逗號分隔，留空則不限制）
# 正式環境建議設定，例如：https://asset.shao.one,http://localhost:3000
ALLOWED_ORIGINS=

# 版本更新檢查 URL 固定由系統內建，不提供環境變數覆蓋
