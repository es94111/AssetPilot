generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  HIGH
  VERY_HIGH
}

enum UnitPreference {
  METRIC
  IMPERIAL
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String
  name               String
  gender             Gender?
  birthDate          DateTime?
  heightCm           Float?
  activityLevel      ActivityLevel  @default(MODERATE)
  unitPreference     UnitPreference @default(METRIC)
  language           String         @default("zh-TW")
  dailyCalorieTarget Int?
  dailyWaterTargetMl Int?           @default(2000)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  bodyRecords BodyRecord[]
  mealLogs    MealLog[]
  waterLogs   WaterLog[]
  customFoods Food[]       @relation("CustomFoods")
}

model BodyRecord {
  id              String   @id @default(cuid())
  userId          String
  recordedAt      DateTime
  weightKg        Float?
  bodyFatPct      Float?
  muscleMassKg    Float?
  visceralFatLevel Int?
  bodyWaterPct    Float?
  bmrKcal         Int?
  chestCm         Float?
  waistCm         Float?
  hipCm           Float?
  upperArmCm      Float?
  thighCm         Float?
  calfCm          Float?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
}

model Food {
  id              String   @id @default(cuid())
  name            String
  category        String?
  caloriesPer100g Float
  carbsG          Float
  proteinG        Float
  fatG            Float
  fiberG          Float?
  sodiumMg        Float?
  barcode         String?
  isCustom        Boolean  @default(false)
  createdById     String?
  createdAt       DateTime @default(now())

  createdBy User?     @relation("CustomFoods", fields: [createdById], references: [id], onDelete: SetNull)
  mealLogs  MealLog[]
}

model MealLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  mealType    MealType
  foodId      String
  foodName    String
  quantityG   Float
  caloriesKcal Float
  carbsG      Float
  proteinG    Float
  fatG        Float
  note        String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId, date])
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  loggedAt  DateTime
  amountMl  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}
